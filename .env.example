# Copy this to .env and fill values for your environment. Do NOT commit real secrets to Git.

# Postgres
POSTGRES_DB=infrashop
POSTGRES_USER=infrashop
# Set a strong password here for production
POSTGRES_PASSWORD=replace-with-strong-password

# Backend
# JWT secret must be a long, random string
JWT_SECRET=replace-with-very-strong-secret

# Optional: override DATABASE_URL if you prefer
# DATABASE_URL=postgresql://infrashop:replace-with-strong-password@db:5432/infrashop

# Other secrets (SMTP, API keys) - add as needed
# SMTP_USER=
# SMTP_PASSWORD=
# SENTRY_DSN=
